# Maintainer: Simon Kenny Panigrahi <simonkp.live@gmail.com>
pkgname=oled-screensaver
pkgver=1.0.0
pkgrel=1
pkgdesc="OLED-safe black screensaver for Ubuntu/GNOME (Wayland + X11)"
arch=('any')
url="https://github.com/simonpanigrahi/Ubuntu-Screensaver"
license=('MIT')
depends=('bash' 'python-gobject' 'gtk3')
source=("$pkgname-$pkgver.tar.gz::https://github.com/simonpanigrahi/Ubuntu-Screensaver/archive/refs/tags/v$pkgver.tar.gz")
sha256sums=('e053473062f2ee9f57ec26f9d4952e349d5dd3addc791c45f7a798cf82a9f41e')

package() {
    cd "$srcdir/Ubuntu-Screensaver-$pkgver"
    install -Dm755 oled-safe.sh "$pkgdir/usr/bin/screensaver"
    install -Dm644 LICENSE "$pkgdir/usr/share/licenses/$pkgname/LICENSE"
}
